{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Teams",
  "description": "Array of team records (teams*.json)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["UniqueName", "Name"],
    "additionalProperties": true,
    "properties": {
      "UniqueName": {
        "type": "string",
        "pattern": "^[a-z0-9.]+$",
        "description": "Stable identifier - accepted lowercase letters, digits, and dots. Referenced by LineUp.Team, Championship.Teams[]."
      },
      "Name":             { "type": "string", "minLength": 1 },
      "FullName":         { "type": "string" },
      "Abbreviation":     { "type": "string" },
      "Car":              { "type": "string", "description": "cars.UniqueName" },
      "Nationality":      { "type": "string", "description": "nations.Name" },
      "Position":         { "type": "integer" },
      "Color":            { "$ref": "#/$defs/colour" },
      "SecondaryColor":   { "$ref": "#/$defs/colour" },
      "TertiaryColor":    { "$ref": "#/$defs/colour" },
      "ColorRaw":         { "type": "integer", "const": 0, "description": "Legacy — keep at 0." },
      "SecondaryColorRaw":{ "type": "integer", "const": 0, "description": "Legacy — keep at 0." },
      "Year":             { "type": "integer" },
      "Seats":            { "type": "integer", "minimum": 0 },
      "AliasesRaw":       { "type": "string" },
      "Origin":           { "type": "string" },
      "Prestige":         { "type": "integer" }
    }
  },
  "$defs": {
    "colour": {
      "description": "RltColor.Parse() format: #RRGGBB, #AARRGGBB, R,G,B or R,G,B,A. Empty string means no colour.",
      "type": "string",
      "anyOf": [
        { "const": "" },
        { "pattern": "^#[0-9A-Fa-f]{6}$" },
        { "pattern": "^#[0-9A-Fa-f]{8}$" },
        { "pattern": "^(25[0-5]|2[0-4]\\d|1?\\d{1,2}),(25[0-5]|2[0-4]\\d|1?\\d{1,2}),(25[0-5]|2[0-4]\\d|1?\\d{1,2})$" },
        { "pattern": "^(25[0-5]|2[0-4]\\d|1?\\d{1,2}),(25[0-5]|2[0-4]\\d|1?\\d{1,2}),(25[0-5]|2[0-4]\\d|1?\\d{1,2}),(25[0-5]|2[0-4]\\d|1?\\d{1,2})$" }
      ]
    }
  }
}
