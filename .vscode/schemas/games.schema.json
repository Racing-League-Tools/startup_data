{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Games",
  "description": "Array of simulation game / platform records (games*.json)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["UniqueName", "Name"],
    "additionalProperties": true,
    "properties": {
      "UniqueName":   {
        "type": "string",
        "pattern": "^[a-z0-9.]+$",
        "description": "Stable identifier - accepted lowercase letters, digits, and dots. Referenced by Championship.Games[]."
      },
      "Name":         { "type": "string", "minLength": 1, "description": "Display name, e.g. \"F1 2024\"." },
      "Developer":    { "type": "string" },
      "Publisher":    { "type": "string" },
      "ReleaseDate":  { "type": "string" },
      "PlatformsRaw": { "type": "string", "description": "Comma-separated platform list." },
      "OfficialLink": { "type": "string" }
    }
  }
}
